<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Screen?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Pane?>

<AnchorPane fx:controller="org.baseplayer.controllers.MainController" prefHeight="${screen.visualBounds.height * 0.8}" prefWidth="${screen.visualBounds.width * 0.8}" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" nodeOrientation="LEFT_TO_RIGHT" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" >
  <fx:define>
    <Screen fx:factory="getPrimary" fx:id="screen"/>
  </fx:define>
  <children>
    <VBox layoutX="1.0"  AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
      <children>
        <fx:include source="MenuBar.fxml" />
        
        <SplitPane fx:id="mainSplit" dividerPositions="0.55, 0.70" orientation="VERTICAL" VBox.vgrow="ALWAYS">
          <items>
            <AnchorPane fx:id="chromPane" minWidth="0.0">
              <SplitPane fx:id="chromSplit" dividerPositions="0.15" orientation="HORIZONTAL"
                AnchorPane.topAnchor="0" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0">
                <items>
                  <StackPane fx:id="genomeSideBarPane" minHeight="50" minWidth="50" styleClass="sidebar-panel" />
                  <SplitPane fx:id="chromosomeSplitPane" minHeight="0.0" minWidth="0.0"
                        AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" />
                </items>
              </SplitPane>
              <Pane fx:id="chromScroll" minHeight="10" minWidth="10" maxWidth="10" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" />
            </AnchorPane>
            <AnchorPane fx:id="featureTracksPane" minHeight="18" prefHeight="40">
              <SplitPane fx:id="featureTracksSplit" dividerPositions="0.15" orientation="HORIZONTAL"
                AnchorPane.topAnchor="0" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0">
                <items>
                  <StackPane fx:id="featureTracksSideBarPane" minWidth="50" minHeight="0" styleClass="sidebar-panel" />
                  <SplitPane fx:id="featureTracksContentSplit" minHeight="0.0" minWidth="0" />
                </items>
              </SplitPane>
              <Pane fx:id="featureTracksScroll" minHeight="10" minWidth="10" maxWidth="10" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" />
            </AnchorPane>
            <AnchorPane minHeight="0.0" minWidth="0.0" VBox.vgrow="ALWAYS">   
              <SplitPane fx:id="drawSplit" dividerPositions="0.15" orientation="HORIZONTAL"
                AnchorPane.topAnchor="0" AnchorPane.rightAnchor="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0">
                <items>
                  <SplitPane fx:id="drawSideBar" minHeight="50" minWidth="50" styleClass="sidebar-panel"
                    AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" >
                    <items>
                      <StackPane fx:id="drawSideBarStackPane" minWidth="0" minHeight="0" />
                    </items>
                  </SplitPane>        
                  <SplitPane fx:id="alignmentSplitPane" minHeight="0.0" minWidth="0" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" />
                </items>
              </SplitPane>
              <Pane fx:id="drawScroll" minHeight="10" minWidth="10" maxWidth="10" AnchorPane.topAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" />
            </AnchorPane>
          </items>
        </SplitPane>
      </children>
    </VBox>
  </children>
</AnchorPane>
